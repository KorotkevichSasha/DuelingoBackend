# Copy this file to .env and replace every CHANGE_ME value locally.
# Never commit the resulting .env file.
PG_CONTAINER_NAME=duelingo-postgres
POSTGRES_USER=duelingo
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=duelingo_db

MONGO_CONTAINER_NAME=duelingo-mongo
MONGO_INITDB_ROOT_USERNAME=duelingo
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME

REDIS_CONTAINER_NAME=duelingo-redis
REDIS_PASSWORD=CHANGE_ME

APP_CONTAINER_NAME=duelingo-app
JWT_SIGNING_KEY=CHANGE_ME_BASE64_ENCODED_32_BYTE_KEY
ALLOWED_ORIGINS=http://localhost:5173

SPRING_MAIL_USERNAME=CHANGE_ME
SPRING_MAIL_PASSWORD=CHANGE_ME

MONGO_EXPRESS_CONTAINER_NAME=mongo-express
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=CHANGE_ME
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
